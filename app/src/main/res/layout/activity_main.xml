<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/frame_bg">

    <!-- Live camera fills the whole screen -->
    <ImageView
        android:id="@+id/frameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/frame_bg"
        android:contentDescription="Camera preview"
        android:scaleType="centerCrop" />

    <!-- Slim gradient only at the very top for header legibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_scrim_top" />

    <!-- Slim gradient only at the bottom behind the controls -->
    <View
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_scrim_bottom" />

    <!-- ───────────────── Top header ───────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="40dp"
        android:paddingEnd="18dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FilterLens"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/modeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUDIO REACTIVE STUDIO"
                android:textColor="@color/studio_accent"
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/fpsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_metric_pill"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="-- fps"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ───────────────── Bottom control bar ───────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="18dp">

        <!-- Filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/chipRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipNone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Original"
                    android:textColor="@color/chip_text_selected"
                    app:chipBackgroundColor="@color/chip_selected_bg" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGrayscale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Grayscale"
                    android:textColor="@color/chip_text_unselected"
                    app:chipBackgroundColor="@color/chip_unselected_bg" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBlur"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Blur"
                    android:textColor="@color/chip_text_unselected"
                    app:chipBackgroundColor="@color/chip_unselected_bg" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSharpen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Sharpen"
                    android:textColor="@color/chip_text_unselected"
                    app:chipBackgroundColor="@color/chip_unselected_bg" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEdges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edges"
                    android:textColor="@color/chip_text_unselected"
                    app:chipBackgroundColor="@color/chip_unselected_bg" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Compact status row: filter name + badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/activeFilterLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto filter: Original"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filter_badge"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="ORIGINAL"
                android:textColor="@color/chip_text_selected"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Sound meter + numeric dB -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/soundLevelProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_sound_meter" />

            <TextView
                android:id="@+id/dbHeroText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="--"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dbText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="dBFS"
                android:textColor="@color/status_text"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Slim spectrum visualizer -->
        <com.mediaplatform.app.AudioVisualizerView
            android:id="@+id/visualizerView"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp" />

        <!-- Hidden pipeline status (kept for state binding) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/pipelineCameraText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAMERA LIVE" />

            <TextView
                android:id="@+id/pipelineMicText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIC LISTENING" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/permissionLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/permission_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FilterLens"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/permission_required"
            android:textColor="@color/status_text"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantPermission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/grant_permission"
            app:cornerRadius="24dp" />

    </LinearLayout>

</FrameLayout>
