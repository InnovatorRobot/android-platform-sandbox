<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/frame_bg">

    <!-- ── Live filtered frame ───────────────────────────────────────────── -->
    <ImageView
        android:id="@+id/frameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@color/frame_bg"
        android:contentDescription="Camera preview" />

    <!-- ── Top bar ────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:background="#88000000">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CamFilters"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/fpsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/teal_200" />

    </LinearLayout>

    <!-- ── Bottom controls ───────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/overlay_bg"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Filter chip row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/chipRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Original -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipNone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Original"
                    android:layout_marginEnd="8dp"
                    app:chipBackgroundColor="@color/chip_selected_bg"
                    android:textColor="@color/chip_text_selected" />

                <!-- Grayscale -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGrayscale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grayscale"
                    android:layout_marginEnd="8dp"
                    app:chipBackgroundColor="@color/chip_unselected_bg"
                    android:textColor="@color/chip_text_unselected" />

                <!-- Blur -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBlur"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blur"
                    android:layout_marginEnd="8dp"
                    app:chipBackgroundColor="@color/chip_unselected_bg"
                    android:textColor="@color/chip_text_unselected" />

                <!-- Sharpen -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSharpen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sharpen"
                    android:layout_marginEnd="8dp"
                    app:chipBackgroundColor="@color/chip_unselected_bg"
                    android:textColor="@color/chip_text_unselected" />

                <!-- Edges -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEdges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edges"
                    app:chipBackgroundColor="@color/chip_unselected_bg"
                    android:textColor="@color/chip_text_unselected" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Active filter label -->
        <TextView
            android:id="@+id/activeFilterLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filter: Original"
            android:textSize="12sp"
            android:textColor="@color/status_text"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

    </LinearLayout>

    <!-- ── No-permission overlay (hidden by default) ─────────────────────── -->
    <LinearLayout
        android:id="@+id/permissionLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/permission_bg"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permission_required"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantPermission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/grant_permission"
            app:cornerRadius="24dp" />

    </LinearLayout>

</FrameLayout>

